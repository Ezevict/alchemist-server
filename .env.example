# ═══════════════════════════════════════════════════
# THE ALCHEMIST SERVER — Environment Variables
# Copy this to .env and fill in your real values
# NEVER commit .env to GitHub
# ═══════════════════════════════════════════════════

# Claude API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your Telegram Chat ID (get from @userinfobot)
# For a group/channel use the negative ID e.g. -100123456789
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Optional: webhook security (any random string)
# Set the same string in TradingView alert headers
WEBHOOK_SECRET=

# Server port (Railway/Render set this automatically)
PORT=5000

# Enable debug logging (set to true during testing only)
DEBUG=false
